@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row g-2">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">Controle de Medicamentos</h1>
        <p class="lead text-secondary mb-4">
            Gerencie funcionários, pacientes, medicamentos e estoque de forma simples e organizada.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Home" asp-action="Index">Início</a>
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Contatos" asp-action="Listar">Contatos</a>
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Compromissos"
               asp-action="Listar">Compromissos</a>
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Categoria" asp-action="Listar">Categorias</a>
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Despesa" asp-action="Listar">Despesas</a>
        </div>

    </div>

    <div class="col-lg-5">
        <div class="card border-primary-subtle shadow-sm">
            <div class="card-body p-4">
                <h3 class="h5 text-primary mb-3">Módulos disponíveis</h3>

                <div class="list-group">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Tarefas" asp-action="Listar">
                        Tarefas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>
