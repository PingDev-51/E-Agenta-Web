@using E_Agenda.WebApp.Modulos.ModuloCompromissos.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Compromissos";
}

@model List<ListarCompromissosViewModels>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum compromisso cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarCompromissosViewModels c in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@c.Assunto</h5>
                            <span class="badge text-bg-primary rounded-pill">@c.TipoDeCompromisso</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Data</dt>
                            <dd class="col-7 mb-0">@c.DataOcorrencia.ToString("dd/MM/yyyy")</dd>

                            <dt class="col-5 text-secondary fw-semibold">Horário</dt>
                            <dd class="col-7 mb-0">@c.HoraDeIncio.ToString(@"hh\:mm") - @c.HoraDeTermino.ToString(@"hh\:mm")
                            </dd>

                            <dt class="col-5 text-secondary fw-semibold">Contato</dt>
                            <dd class="col-7 mb-0 text-break">@(string.IsNullOrWhiteSpace(c.Contato) ? "Não informado" :
                                                        c.Contato)</dd>

                                <dt class="col-5 text-secondary fw-semibold">Local</dt>
                                <dd class="col-7 mb-0 text-break">@(string.IsNullOrWhiteSpace(c.Local) ? "Não informado" : c.Local)
                                </dd>

                                <dt class="col-5 text-secondary fw-semibold">Link</dt>
                                <dd class="col-7 mb-0 text-break">@(string.IsNullOrWhiteSpace(c.Link) ? "Não informado" : c.Link)
                                </dd>
                            </dl>

                            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                                   asp-route-id="@c.Id">Editar</a>
                                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                                   asp-route-id="@c.Id">Excluir</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }