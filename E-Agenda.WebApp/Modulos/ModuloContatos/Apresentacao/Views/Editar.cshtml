@using EAgendaWeb.WebApp.Modulos.ModuloDespesas.Apresentacao
@using EAgendaWeb.WebApp.Modulos.ModuloDespesas.Dominio
@using E_Agenda.WebApp.Modulos.ModuloContatos.Apresentacao

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Editar de Contatos";
}

@model EditarContatosViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width:620px;" asp-action="Editar"
      asp-route-id="@Model.Id" method="post">

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Nome" type="text" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Email" type="text" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Telefone" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Telefone" type="text" step="0.01" class="form-control" />
        <span asp-validation-for="Telefone" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cargo" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Cargo" type="text" step="0.01" class="form-control" />
        <span asp-validation-for="Cargo" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Empresa" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Empresa" type="text" step="0.01" class="form-control" />
        <span asp-validation-for="Empresa" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Listar" class="btn btn-outline-primary rounded-pill px-4">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4">Confirmar</button>
    </div>

</form>