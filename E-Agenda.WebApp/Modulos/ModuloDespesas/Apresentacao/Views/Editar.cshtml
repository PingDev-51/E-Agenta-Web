@using EAgendaWeb.WebApp.Modulos.ModuloDespesas.Apresentacao
@using EAgendaWeb.WebApp.Modulos.ModuloDespesas.Dominio

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Despesa";
}

@model EditarDespesaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4"
      style="max-width:620px;"
      asp-action="Editar"
      asp-route-id="@Model.Id"
      method="post">

    <input asp-for="Id" type="hidden"/>

    <div class="mb-3">
        <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Descricao" class="form-control"/>
        <span asp-validation-for="Descricao" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DataOcorrencia" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="DataOcorrencia" type="date" class="form-control"/>
    </div>

    <div class="mb-3">
        <label asp-for="Valor" class="form-label fw-semibold text-primary text-uppercase small"></label>
        <input asp-for="Valor" type="number" step="0.01" class="form-control"/>
        <span asp-validation-for="Valor" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FormaPagamento" class="form-label fw-semibold text-primary text-uppercase small"></label>

        <select asp-for="FormaPagamento"
                asp-items="Html.GetEnumSelectList<FormaPagamento>()"
                class="form-select">
        </select>

        <span asp-validation-for="FormaPagamento" class="text-danger small fw-semibold"></span>
    </div>

    @*
    <div class="mb-3">
        <label asp-for="CategoriasIds"></label>

        <select asp-for="CategoriasIds"
                asp-items="Model.CategoriasDisponiveis"
                multiple
                class="form-select">
        </select>

        <span asp-validation-for="CategoriasIds"></span>
    </div>
    *@

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Listar" class="btn btn-outline-primary rounded-pill px-4">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4">Confirmar</button>
    </div>

</form>