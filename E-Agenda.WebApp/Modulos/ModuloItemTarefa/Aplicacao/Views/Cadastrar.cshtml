@using EAgendaWeb.WebApp.Modulos.ModuloItensTarefa.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Item";
}

@model CadastroItemTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4"
      style="max-width:620px"
      asp-action="Cadastrar"
      method="post">

    <input asp-for="TarefaId" type="hidden"/>

    <div class="mb-3">

        <label asp-for="Titulo"
               class="form-label fw-semibold text-primary text-uppercase small">
            Título
        </label>

        <input asp-for="Titulo"
               class="form-control"/>

        <span asp-validation-for="Titulo"
              class="text-danger small fw-semibold">
        </span>

    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">

        <a class="btn btn-outline-primary rounded-pill px-4"
           asp-action="Listar"
           asp-route-tarefaId="@Model.TarefaId">
            Voltar
        </a>

        <button class="btn btn-primary rounded-pill px-4"
                type="submit">
            Confirmar
        </button>

    </div>

</form>