@using EAgendaWeb.WebApp.Modulos.ModuloItensTarefa.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Item";
}

@model ExcluirItemTarefaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4"
      style="max-width:620px"
      asp-action="Excluir"
      method="post">

    <input asp-for="Id" type="hidden"/>
    <input asp-for="TarefaId" type="hidden"/>

    <div class="alert alert-primary border-start border-primary border-4 rounded-3">
        Deseja realmente excluir este item?
    </div>

    <div class="mb-3">

        <label class="form-label fw-semibold text-primary text-uppercase small">
            Título
        </label>

        <input asp-for="Titulo"
               class="form-control"
               disabled/>

    </div>

    <div class="mb-3">

        <label class="form-label fw-semibold text-primary text-uppercase small">
            Concluído
        </label>

        <input class="form-control"
               value="@(Model.Concluido ? "Sim" : "Não")"
               disabled/>

    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">

        <a class="btn btn-outline-primary rounded-pill px-4"
           asp-action="Listar"
           asp-route-tarefaId="@Model.TarefaId">
            Voltar
        </a>

        <button class="btn btn-danger rounded-pill px-4"
                type="submit">
            Excluir
        </button>

    </div>

</form>