@using EAgendaWeb.WebApp.Modulos.ModuloTarefas.Apresentacao
@using EAgendaWeb.WebApp.Modulos.ModuloTarefas.Dominio
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Tarefa";
}


@model EditarTarefaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4"
      style="max-width: 620px;"
      asp-action="Editar"
      asp-route-id="@Model.Id"
      method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">
            Título
        </label>
        <input asp-for="Titulo" class="form-control" />
        <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Prioridade" class="form-label fw-semibold text-primary text-uppercase small">
            Prioridade
        </label>
        <select asp-for="Prioridade"
                asp-items="Html.GetEnumSelectList<PrioridadeTarefa>()"
                class="form-select">
        </select>
        <span asp-validation-for="Prioridade" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PercentualConcluido" class="form-label fw-semibold text-primary text-uppercase small">
            Percentual Concluído
        </label>
        <input asp-for="PercentualConcluido"
               type="number"
               min="0"
               max="100"
               class="form-control" />
        <span asp-validation-for="PercentualConcluido" class="text-danger small fw-semibold"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Concluida" class="form-check-input" />
        <label asp-for="Concluida" class="form-check-label">
            Tarefa concluída
        </label>
    </div>

    <div class="mb-3">
        <label asp-for="DataConclusao" class="form-label fw-semibold text-primary text-uppercase small">
            Data de Conclusão
        </label>
        <input asp-for="DataConclusao"
               type="datetime-local"
               class="form-control" />
        <span asp-validation-for="DataConclusao" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4"
           asp-action="Listar">
            Voltar
        </a>

        <button class="btn btn-primary rounded-pill px-4"
                type="submit">
            Confirmar
        </button>
    </div>
</form>